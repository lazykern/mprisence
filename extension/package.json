{
  "name": "mprisence-bridge",
  "version": "1.0.2",
  "description": "Provides rich web media player metadata from your browser to MPRIS",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --experimental-strip-types --test 'src/**/*.test.ts'",
    "build:firefox": "node build.mjs firefox",
    "build:chromium": "node build.mjs chromium",
    "build:all": "node build.mjs firefox && node build.mjs chromium",
    "build:chromium:store": "node build.mjs chromium --store",
    "build:firefox:store": "node build.mjs firefox --store",
    "build:store": "node build.mjs firefox --store && node build.mjs chromium --store",
    "package:store": "npm run build:store",
    "watch:firefox": "node build.mjs firefox --watch",
    "watch:chromium": "node build.mjs chromium --watch"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "@types/webextension-polyfill": "^0.12.0"
  }
}
