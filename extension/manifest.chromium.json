{
  "manifest_version": 3,
  "name": "mprisence bridge",
  "version": "1.0.1",
  "description": "Provides rich web media player metadata from your browser to MPRIS",
  "key": "",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["nativeMessaging", "scripting", "storage"],
  "optional_host_permissions": ["<all_urls>"],
  "minimum_chrome_version": "111",
  "action": {
    "default_title": "mprisence bridge — open settings",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
