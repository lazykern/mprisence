{
  "manifest_version": 3,
  "name": "mprisence bridge",
  "version": "0.1.0",
  "description": "Sends browser media metadata to the mprisence native bridge",
  "key": "",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["nativeMessaging", "tabs"],
  "minimum_chrome_version": "111",
  "action": {
    "default_title": "mprisence bridge",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
