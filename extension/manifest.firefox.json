{
  "manifest_version": 3,
  "name": "mprisence bridge",
  "version": "1.0.2",
  "description": "Provides rich web media player metadata from your browser to MPRIS",
  "homepage_url": "https://github.com/lazykern/mprisence",
  "browser_specific_settings": {
    "gecko": {
      "id": "mprisence-bridge@lazykern.foo",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "permissions": ["nativeMessaging"],
  "action": {
    "default_title": "mprisence bridge",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
