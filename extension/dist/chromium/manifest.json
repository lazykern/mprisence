{
  "manifest_version": 3,
  "name": "mprisence bridge",
  "version": "1.0.2",
  "description": "Provides rich web media player metadata from your browser to MPRIS",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "nativeMessaging"
  ],
  "minimum_chrome_version": "111",
  "action": {
    "default_title": "mprisence bridge",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "*://music.youtube.com/*",
    "*://www.youtube.com/*",
    "*://soundcloud.com/*",
    "*://*.soundcloud.com/*",
    "*://bandcamp.com/*",
    "*://*.bandcamp.com/*",
    "*://tidal.com/*",
    "*://*.tidal.com/*",
    "*://music.apple.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://music.youtube.com/*",
        "*://www.youtube.com/*",
        "*://soundcloud.com/*",
        "*://*.soundcloud.com/*",
        "*://bandcamp.com/*",
        "*://*.bandcamp.com/*",
        "*://tidal.com/*",
        "*://*.tidal.com/*",
        "*://music.apple.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://music.youtube.com/*",
        "*://www.youtube.com/*",
        "*://soundcloud.com/*",
        "*://*.soundcloud.com/*",
        "*://bandcamp.com/*",
        "*://*.bandcamp.com/*",
        "*://tidal.com/*",
        "*://*.tidal.com/*",
        "*://music.apple.com/*"
      ],
      "js": [
        "page-world.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}