{
  "manifest_version": 3,
  "name": "mprisence bridge",
  "version": "0.1.0",
  "description": "Sends browser media metadata to the mprisence native bridge",
  "homepage_url": "https://github.com/lazykern/mprisence",
  "browser_specific_settings": {
    "gecko": {
      "id": "mprisence-bridge@lazykern.github.io",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "permissions": [
    "nativeMessaging",
    "tabs"
  ],
  "action": {
    "default_title": "mprisence bridge",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "*://music.youtube.com/*",
    "*://www.youtube.com/*",
    "*://soundcloud.com/*",
    "*://*.soundcloud.com/*",
    "*://bandcamp.com/*",
    "*://*.bandcamp.com/*",
    "*://tidal.com/*",
    "*://*.tidal.com/*",
    "*://music.apple.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://music.youtube.com/*",
        "*://www.youtube.com/*",
        "*://soundcloud.com/*",
        "*://*.soundcloud.com/*",
        "*://bandcamp.com/*",
        "*://*.bandcamp.com/*",
        "*://tidal.com/*",
        "*://*.tidal.com/*",
        "*://music.apple.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://music.youtube.com/*",
        "*://www.youtube.com/*",
        "*://soundcloud.com/*",
        "*://*.soundcloud.com/*",
        "*://bandcamp.com/*",
        "*://*.bandcamp.com/*",
        "*://tidal.com/*",
        "*://*.tidal.com/*",
        "*://music.apple.com/*"
      ],
      "js": [
        "page-world.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}